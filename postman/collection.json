{
  "info": {
    "name": "API Test Generator - Colección Base (Estática)",
    "_postman_id": "api-test-generator-base",
    "description": "Colección base de pruebas estáticas. En el pipeline CI/CD esta colección es REEMPLAZADA por la generada dinámicamente mediante GPT-4.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "createdUserId", "value": "", "type": "string" },
    { "key": "createdProductId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health - API disponible",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiempo < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));",
                  "pm.test('Body tiene status ok', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /api/users - Listar usuarios",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta es array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Tiempo < 2000ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/users - Crear usuario válido",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test User\", \"email\": \"test_{{$randomInt}}@example.com\", \"role\": \"user\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Responde con id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.collectionVariables.set('createdUserId', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/users - Email inválido (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test\", \"email\": \"not-an-email\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Mensaje de error', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/users - Campos requeridos faltantes (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Solo nombre\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/users/:id - Usuario existente",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{createdUserId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID coincide', () => {",
                  "  const id = parseInt(pm.collectionVariables.get('createdUserId'));",
                  "  pm.expect(pm.response.json().id).to.eql(id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/users/99999 - Usuario inexistente (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/users/:id - Eliminar usuario creado",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/{{createdUserId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "GET /api/products - Listar productos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es un array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/products - Crear producto válido",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Producto Test\", \"price\": 99.99, \"stock\": 10, \"category\": \"Test\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Tiene id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('createdProductId', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/products - Precio negativo (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Prod\", \"price\": -5, \"stock\": 10}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "GET /api/orders - Listar órdenes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/orders - Crear orden válida",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\": 1, \"productId\": 1, \"quantity\": 2}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status es pending', () => {",
                  "  pm.expect(pm.response.json().status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/orders - Cantidad 0 (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"userId\": 1, \"productId\": 1, \"quantity\": 0}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
